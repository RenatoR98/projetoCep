<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

        <Style Selector="lvc|CartesianChart.cep-chart">

        <!-- Tamanho do texto da legenda -->
        <Setter Property="LegendTextSize" Value="10" />

        <!-- Tamanho do texto do tooltip quando passa o mouse -->
        <Setter Property="TooltipTextSize" Value="10" />


    </Style>

  <!-- Add Styles Here -->
</Styles>
