<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia">
  <Design.PreviewWith>
    <Border Padding="20">
    </Border>
  </Design.PreviewWith>

    <Style Selector="lvc|CartesianChart.cep-chart">
        <Setter Property="LegendTextSize" Value="7" />
        <Setter Property="TooltipTextSize" Value="7" />
    </Style>

</Styles>
