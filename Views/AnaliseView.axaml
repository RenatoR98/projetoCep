<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="projetoCep.AnaliseView">
    <Border Padding="15">
        <Grid RowDefinitions="1*,1.2*,2.5*,2.5*" RowSpacing="5">
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="5">
					<Grid Grid.Column="0" RowDefinitions="Auto,*">
						<Label Grid.Row="0" FontSize="20" FontWeight="DemiBold">Análises de Processo</Label>
                        <Label Grid.Row="1" FontSize="11">Acompanhe o desempenho do processo</Label>
                    </Grid>
                    <Button Grid.Column="1" Background="Gray" FontSize="13" Content="01/04/2024 - 05/04/2024"></Button>
                    <Button Grid.Column="2" Background="Gray" FontSize="13" Content="Filtros"></Button>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="Black"></Border>
            <Border Grid.Row="2" Background="#101820" BorderBrush="#253649" BorderThickness="1" CornerRadius="10" Padding="7" BoxShadow="0 8 24 0 #66000000">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
						<Label Grid.Column="1">Carta de Controle</Label>
                        <Button Grid.Column="2" Background="Gray" FontSize="13" Content="7D, 30D, ..."></Button>
                        <Button Grid.Column="3" Background="Gray" FontSize="13" Content="Exportar"></Button>
                        <Button Grid.Column="4" Background="Gray" FontSize="13" Content=":"></Button>
                    </Grid>
                    <Border Grid.Row="1" Classes="Divider"></Border>
                    <lvc:CartesianChart Grid.Row="2" LegendPosition="Hidden" FontSize="5">
                        <lvc:CartesianChart.Series>
							<lvc:XamlLineSeries SeriesName="CL"
                                                Values="{lvc:Values FromString='10, 11, 15, 8, 9, 6, 12, 13, 9, 10'}"
                                                LineSmoothness="0"/>
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.Sections>
							<lvc:XamlRectangularSection Yi="15"
                                                        Yj="15"
                                                        Label="UCL"
                                                        Stroke="{lvc:SolidColorPaint
                                                            Color='#6495ED',
                                                            StrokeWidth=4,
                                                            PathEffect={lvc:Dashed Array='30, 20'}}"/>
                            <lvc:XamlRectangularSection Yi="5"
                                                        Yj="5"
                                                        Label="LCL"
                                                        Stroke="{lvc:SolidColorPaint
                                                            Color='#6495ED',
                                                            StrokeWidth=4,
                                                            PathEffect={lvc:Dashed Array='30, 20'}}"/>
                        </lvc:CartesianChart.Sections>
                    </lvc:CartesianChart>
                </Grid>
            </Border>
            <Border Grid.Row="3" Background="Black"></Border>
        </Grid>
    </Border>

</UserControl>
